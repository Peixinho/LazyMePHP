# =============================================================================
# ENVIRONMENT AND CONFIGURATION
# =============================================================================
.env
.env.*
!.env.example
.maintenance

# =============================================================================
# COMPOSER
# =============================================================================
vendor
composer.lock

# =============================================================================
# APPLICATION FILES
# =============================================================================
# App/Models, App/Controllers, App/Views, App/Routes, and App/Api are NOT
# generated output — they hold hand-written and `make:*`-scaffolded files
# (controllers, views, route overrides, custom REST endpoints) that must be
# tracked like any other source. Only the Blade compiled-view cache is ignored.
App/Views/_compiled/*
!App/Views/_compiled/.placeholder

# Tools and descriptors
tools/.descriptors


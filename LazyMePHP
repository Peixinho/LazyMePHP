    /** Convert a table_name into a StudlyCase class name. */
    private function studly(string $value): string {
        return str_replace(' ', '', ucwords(str_replace(['_', '-'], ' ', $value)));
    }

    private function isInteractive(): bool {
        return stream_isatty(STDIN);
    }

    private function promptYesNo(string $message): bool {
        echo "$message [y/N]: ";
        $answer = strtolower(trim((string)fgets(STDIN)));
        return $answer === 'y' || $answer === 'yes';
    }

    private function makeView(string $tableName): void {
        $srcDir = __DIR__ . '/App/Views/_Crud';
        $dstDir = __DIR__ . "/App/Views/{$tableName}";
        if (!is_dir($dstDir)) mkdir($dstDir, 0755, true);

        foreach (['index', 'edit'] as $action) {
            $dst = "{$dstDir}/{$action}.blade.php";
            if (file_exists($dst)) {
                echo "Already exists, skipping: $dst\n";
                continue;
            }
            copy("{$srcDir}/{$action}.blade.php", $dst);
            echo "Created: $dst\n";
        }
        echo "These override the generic _Crud templates for '{$tableName}' only — edit freely.\n";
    }


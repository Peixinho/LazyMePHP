        echo "Created: $file\n";
    }

    private function makeModel(string $name, ?string $dbTable = null): void {
        $dir  = __DIR__ . '/App/Models';
        if (!is_dir($dir)) mkdir($dir, 0755, true);
        $file = "$dir/{$name}.php";
        if (file_exists($file)) { echo "Model already exists: $file\n"; exit(1); }
        $table = $dbTable ?? (strtolower($name) . 's');

        $fillableLine = '';
        if ($dbTable) {
            try {
                $schema = \Core\Model::schemaFor($dbTable);
                $cols   = array_filter(array_keys($schema), fn($c) => !($schema[$c]['pk'] ?? false));
                if (!empty($cols)) {
                    $list = implode("', '", $cols);
                    $fillableLine = "\n    protected static array \$fillable = ['{$list}'];\n";
                }
            } catch (\Throwable) {
                // Schema not available — skip fillable
            }
        }

        file_put_contents($file, "<?php\n\ndeclare(strict_types=1);\n\nnamespace Models;\n\nuse Core\\Model;\n\nclass {$name} extends Model\n{\n    protected static string \$table = '{$table}';\n{$fillableLine}\n    // protected static array \$rules = [\n    //     'name' => 'required|max:255',\n    // ];\n}\n");
        echo "Created: $file\n";
    }

    private function queueFailed(string $queue): void {
        $jobs = \Core\Queue\Queue::failed($queue);
        if (empty($jobs)) {
            echo "No failed jobs on '{$queue}'.\n";
            return;
        }
        printf("%-6s %-40s %-20s %s\n", 'ID', 'Job', 'Failed At', 'Error');
        echo str_repeat('-', 100) . "\n";
        foreach ($jobs as $job) {
            printf(
                "%-6s %-40s %-20s %s\n",
                $job['id'] ?? '?',
                substr($job['job_class'] ?? '?', 0, 40),
                $job['failed_at'] ?? '?',
                substr($job['error'] ?? '', 0, 40)
            );
        }
    }

    private function routeList(): void {
        $tables = \Core\Model::listTables();
        $hidden = array_filter($tables, fn($t) => \Core\CrudController::isHidden($t));
        $visible = array_values(array_diff($tables, $hidden));

        printf("%-8s %-40s %s\n", 'Method', 'Path', 'Handler');
        echo str_repeat('-', 80) . "\n";

        // Auth routes
        foreach (['POST /auth/login', 'POST /auth/refresh', 'POST /auth/logout', 'GET  /auth/me'] as $r) {
            [$m, $p] = explode(' ', $r, 2);
            printf("%-8s %-40s %s\n", trim($m), $p, 'Core\\Auth\\AuthEndpoint');
        }
        // POST /auth/forgot-password, /auth/reset-password, /auth/verify-email
        foreach (['POST /auth/forgot-password', 'POST /auth/reset-password', 'POST /auth/verify-email'] as $r) {
            [$m, $p] = explode(' ', $r, 2);
            printf("%-8s %-40s %s\n", trim($m), $p, 'Core\\Auth\\AuthEndpoint');
        }
        // GraphQL
        printf("%-8s %-40s %s\n", 'POST', '/graphql', 'Core\\GraphQL\\Endpoint');
        // CRUD routes
        foreach ($visible as $table) {
            $methods = [
                ['GET',  "/$table",           "CrudController::index"],
                ['GET',  "/$table/new",        "CrudController::edit"],
                ['GET',  "/$table/{id}/edit",  "CrudController::edit"],
                ['POST', "/$table/{id}",       "CrudController::save"],
                ['POST', "/$table",            "CrudController::save"],
                ['POST', "/$table/{id}/delete","CrudController::delete"],
            ];
            foreach ($methods as [$method, $path, $handler]) {
                printf("%-8s %-40s %s\n", $method, $path, $handler);
            }
        }
    }

    private function optimize(): void {
        echo "Warming schema cache...\n";
        $tables = \Core\Model::listTables();
        foreach ($tables as $table) {
            \Core\Model::warmSchemaCache($table);
            echo "  Cached: $table\n";
        }
        echo "Optimizing Composer autoloader...\n";
        @exec('composer dump-autoload --optimize --quiet 2>&1', $out, $code);
        foreach ($out as $line) echo "  $line\n";
        echo $code === 0 ? "Done.\n" : "Composer optimize failed (exit $code).\n";
    }

    private function schemaClear(?string $tableName): void {
        if ($tableName) {
            \Core\Model::clearFileSchemaCache($tableName);
            echo "Cleared schema cache for: $tableName\n";
            return;
        }

        \Core\Model::clearFileSchemaCache();
        echo "Cleared all schema cache files.\n";
    }

    private function getPort(int $default): int {
        echo "\n$default:?";
        $port = trim(fgets(STDIN));
        
        if (strlen($port) > 0 && !intval($port)) {
            echo "Invalid port, please try again\n";
            return $this->getPort($default);
        }
        
        if (strlen($port) == 0) {
            return $default;
        }
        
        return intval($port);
    }

    /**
     * Get HTML input type based on database field type
     */
    private function getInputType(string $dbType): string {
        $type = strtolower($dbType);
        
        if (strpos($type, 'text') !== false || strpos($type, 'varchar') !== false) {
            return 'text';
        }
        
        if (strpos($type, 'int') !== false) {
            return 'number';
        }
        
        if (strpos($type, 'float') !== false || strpos($type, 'decimal') !== false) {
            return 'number';
        }
        
        if (strpos($type, 'date') !== false) {
            return 'date';
        }
        
        if (strpos($type, 'time') !== false) {
            return 'time';
        }
        
        if (strpos($type, 'datetime') !== false) {
            return 'datetime-local';
        }
        
        if (strpos($type, 'bool') !== false) {
            return 'checkbox';
        }
        
        if (strpos($type, 'text') !== false && strpos($type, 'long') !== false) {
            return 'textarea';
        }
        
        return 'text';
    }

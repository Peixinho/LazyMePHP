    /** Verify a database is configured and reachable before running DB-dependent commands. */
    private function requireDatabase(string $command): void
    {
        $type = strtolower($_ENV['DB_TYPE'] ?? '');
        if ($type === '') {
            echo "\033[31mError:\033[0m No database configured for '{$command}'.\n";
            echo "Add DB_TYPE (and related vars) to your .env file:\n\n";
            echo "  DB_TYPE=sqlite\n";
            echo "  DB_FILE_PATH=database/database.sqlite\n\n";
            echo "Or for MySQL:\n\n";
            echo "  DB_TYPE=mysql\n";
            echo "  DB_HOST=127.0.0.1\n";
            echo "  DB_NAME=mydb\n";
            echo "  DB_USER=root\n";
            echo "  DB_PASSWORD=secret\n\n";
            exit(1);
        }

        // Quick connection smoke-test
        try {
            \Core\LazyMePHP::DB_CONNECTION();
        } catch (\Throwable $e) {
            echo "\033[31mDatabase connection failed:\033[0m " . $e->getMessage() . "\n";
            echo "Check your .env DB_* settings and make sure the server is running.\n";
            exit(1);
        }
    }


    private function makeView(?string $tableName): void {
        echo "\n\u{1F4A1} Views are powered by generic Blade templates in App/Views/_Crud/ — no code generation needed.\n";
        if ($tableName) {
            echo "   To override for '{$tableName}', create:\n";
            echo "     App/Views/{$tableName}/index.blade.php  (list)\n";
            echo "     App/Views/{$tableName}/edit.blade.php   (create / edit)\n";
            echo "   All schema variables (\$schema, \$record, \$pk, \$table, etc.) are passed automatically.\n\n";
        }
    }

    private function makeController(?string $tableName): void {
        echo "\n💡 Controllers are now powered by Core\\CrudController — no code generation needed.\n";
        echo "   Routes use CrudController::forTable() and auto-discover Controllers\\{Table} subclasses.\n";
        echo "   To add custom behaviour, create App/Controllers/{$tableName}.php extending CrudController.\n\n";
    }

    private function makeRoute(?string $tableName): void {
        echo "\n\u{1F4A1} Routes are now powered by Core\\AutoRouter — no code generation needed.\n";
        echo "   AutoRouter::registerAll(\$blade) in App/Routes/Routes.php registers all tables at runtime.\n";
        echo "   To add table-specific behaviour, create App/Controllers/{$tableName}.php extending CrudController.\n\n";
    }

    private function makeAll(?string $tableName): void {
        $this->makeView($tableName);
        $this->makeController($tableName);
        $this->makeRoute($tableName);
        $this->makeApi($tableName);
    }

    private function makeApi(?string $tableName): void {
        echo "\n\u{1F4A1} The API is now a GraphQL endpoint at POST /graphql — no code generation needed.\n";
        echo "   Core\\GraphQL\\SchemaBuilder builds the schema from all tables at runtime.\n";
        if ($tableName) {
            echo "   To restrict fields for '$tableName', override exposedFields() in App/Controllers/{$tableName}.php:\n\n";
            echo "     protected function exposedFields(): array {\n";
            echo "         return ['id', 'name', ...]; // list fields to expose\n";
            echo "     }\n\n";
        }
    }

    private function schemaCache(?string $tableName): void {
        if ($tableName) {
            echo "Caching schema for table: $tableName\n";
            \Core\Model::warmSchemaCache($tableName);
            echo "Cached App/Cache/schema/$tableName.php\n";
            return;
        }

        $tables = \Core\Model::listTables();
        echo "Caching schema for " . count($tables) . " table(s)...\n";
        foreach ($tables as $table) {
            \Core\Model::warmSchemaCache($table);
            echo "  ✓ $table\n";
        }
        echo "Done. Schema cached to App/Cache/schema/\n";
        echo "Run schema:clear or re-run schema:cache after schema changes.\n";
    }

    private function makeSeeder(string $name): void {
        $dir  = __DIR__ . '/App/Seeders';
        if (!is_dir($dir)) mkdir($dir, 0755, true);
        $file = "$dir/{$name}.php";
        if (file_exists($file)) { echo "Seeder already exists: $file\n"; exit(1); }
        file_put_contents($file, "<?php\n\nclass {$name} extends \\Core\\Seeder\\Seeder\n{\n    public function run(): void\n    {\n        // \$this->insert('table_name', ['column' => 'value']);\n    }\n}\n");
        echo "Created: $file\n";
    }

    private function makeFactory(string $name): void {
        $dir  = __DIR__ . '/App/Factories';
        if (!is_dir($dir)) mkdir($dir, 0755, true);
        $file = "$dir/{$name}.php";
        if (file_exists($file)) { echo "Factory already exists: $file\n"; exit(1); }
        $table = strtolower(preg_replace('/Factory$/i', '', $name)) . 's';
        file_put_contents($file, "<?php\n\nclass {$name} extends \\Core\\Factory\\Factory\n{\n    protected string \$table = '{$table}';\n\n    public function definition(): array\n    {\n        static \$n = 0;\n        \$n++;\n        return [\n            // 'name' => \"Item {\$n}\",\n        ];\n    }\n}\n");
        echo "Created: $file\n";
    }

    private function makeObserver(string $name): void {
        $dir  = __DIR__ . '/App/Observers';
        if (!is_dir($dir)) mkdir($dir, 0755, true);
        $file = "$dir/{$name}.php";
        if (file_exists($file)) { echo "Observer already exists: $file\n"; exit(1); }
        $defaultTable = rtrim(strtolower(preg_replace('/Observer$/', '', $name) ?? $name), '') . 's';
        $tableSlug    = strtolower(preg_replace('/(?<!^)[A-Z]/', '_$0', preg_replace('/Observer$/', '', $name) ?? $name)) . 's';
        file_put_contents($file, "<?php\n\nclass {$name}\n{\n    // Bootstrap auto-discovery reads this to know which model events to attach to.\n    protected static string \$table = '{$tableSlug}';\n\n    public function creating(mixed \$model): void {}\n    public function created(mixed \$model): void {}\n    public function updating(mixed \$model): void {}\n    public function updated(mixed \$model): void {}\n    public function deleting(mixed \$model): void {}\n    public function deleted(mixed \$model): void {}\n}\n");
        echo "Created: $file\n";
    }

    private function makeResource(string $name): void {
        $dir  = __DIR__ . '/App/Resources';
        if (!is_dir($dir)) mkdir($dir, 0755, true);
        $file = "$dir/{$name}.php";
        if (file_exists($file)) { echo "Resource already exists: $file\n"; exit(1); }
        file_put_contents($file, "<?php\n\nclass {$name} extends \\Core\\Http\\ApiResource\n{\n    public function toArray(): array\n    {\n        return \$this->model->toArray();\n    }\n}\n");
        echo "Created: $file\n";
    }

    private function makeJob(string $name): void {
        $dir  = __DIR__ . '/App/Jobs';
        if (!is_dir($dir)) mkdir($dir, 0755, true);
        $file = "$dir/{$name}.php";
        if (file_exists($file)) { echo "Job already exists: $file\n"; exit(1); }
        file_put_contents($file, "<?php\n\ndeclare(strict_types=1);\n\nuse Core\\Queue\\Job;\n\nclass {$name} extends Job\n{\n    public int \$tries = 3;\n\n    // Add public properties for your job payload:\n    // public int \$userId = 0;\n\n    public function handle(): void\n    {\n        // Perform the job here\n    }\n}\n");
        echo "Created: $file\n";
    }

    private function makeRequest(string $name): void {
        $dir  = __DIR__ . '/App/Requests';
        if (!is_dir($dir)) mkdir($dir, 0755, true);
        $file = "$dir/{$name}.php";
        if (file_exists($file)) { echo "FormRequest already exists: $file\n"; exit(1); }
        file_put_contents($file, "<?php\n\ndeclare(strict_types=1);\n\nuse Core\\Http\\FormRequest;\n\nclass {$name} extends FormRequest\n{\n    public function rules(): array\n    {\n        return [\n            // 'name' => 'required|min:2|max:255',\n            // 'email' => 'required|email',\n        ];\n    }\n\n    public function authorize(): bool\n    {\n        return true;\n    }\n}\n");
        echo "Created: $file\n";
    }

    private function makeMail(string $name): void {
        $dir  = __DIR__ . '/App/Mail';
        if (!is_dir($dir)) mkdir($dir, 0755, true);
        $file = "$dir/{$name}.php";
        if (file_exists($file)) { echo "Mailable already exists: $file\n"; exit(1); }
        file_put_contents($file, "<?php\n\ndeclare(strict_types=1);\n\nnamespace App\\Mail;\n\nuse Core\\Mail\\Mail;\nuse Core\\Mail\\Mailable;\n\nclass {$name} extends Mailable\n{\n    public function __construct(\n        // Add constructor parameters for your mail data\n    ) {}\n\n    public function build(Mail \$mail): void\n    {\n        \$mail\n            ->subject('Your subject here')\n            ->html('<p>Your HTML body here.</p>')\n            ->text('Your plain-text body here.');\n    }\n}\n");
        echo "Created: $file\n";
    }

    private function makeModel(string $name, ?string $dbTable = null): void {
        $dir  = __DIR__ . '/App/Models';
        if (!is_dir($dir)) mkdir($dir, 0755, true);
        $file = "$dir/{$name}.php";
        if (file_exists($file)) { echo "Model already exists: $file\n"; exit(1); }
        $table = $dbTable ?? (strtolower($name) . 's');

        $fillableLine = '';
        if ($dbTable) {
            try {
                $schema = \Core\Model::schemaFor($dbTable);
                $cols   = array_filter(array_keys($schema), fn($c) => !($schema[$c]['pk'] ?? false));
                if (!empty($cols)) {
                    $list = implode("', '", $cols);
                    $fillableLine = "\n    protected static array \$fillable = ['{$list}'];\n";
                }
            } catch (\Throwable) {
                // Schema not available — skip fillable
            }
        }

        file_put_contents($file, "<?php\n\ndeclare(strict_types=1);\n\nnamespace Models;\n\nuse Core\\Model;\n\nclass {$name} extends Model\n{\n    protected static string \$table = '{$table}';\n{$fillableLine}\n    // protected static array \$rules = [\n    //     'name' => 'required|max:255',\n    // ];\n}\n");
        echo "Created: $file\n";
    }

    private function schemaClear(?string $tableName): void {
        if ($tableName) {
            \Core\Model::clearFileSchemaCache($tableName);
            echo "Cleared schema cache for: $tableName\n";
            return;
        }

        \Core\Model::clearFileSchemaCache();
        echo "Cleared all schema cache files.\n";
    }

    private function getPort(int $default): int {
        echo "\n$default:?";
        $port = trim(fgets(STDIN));
        
        if (strlen($port) > 0 && !intval($port)) {
            echo "Invalid port, please try again\n";
            return $this->getPort($default);
        }
        
        if (strlen($port) == 0) {
            return $default;
        }
        
        return intval($port);
    }

    /**
     * Get HTML input type based on database field type
     */
    private function getInputType(string $dbType): string {
        $type = strtolower($dbType);
        
        if (strpos($type, 'text') !== false || strpos($type, 'varchar') !== false) {
            return 'text';
        }
        
        if (strpos($type, 'int') !== false) {
            return 'number';
        }
        
        if (strpos($type, 'float') !== false || strpos($type, 'decimal') !== false) {
            return 'number';
        }
        
        if (strpos($type, 'date') !== false) {
            return 'date';
        }
        
        if (strpos($type, 'time') !== false) {
            return 'time';
        }
        
        if (strpos($type, 'datetime') !== false) {
            return 'datetime-local';
        }
        
        if (strpos($type, 'bool') !== false) {
            return 'checkbox';
        }
        
        if (strpos($type, 'text') !== false && strpos($type, 'long') !== false) {
            return 'textarea';
        }
        
        return 'text';
    }
}

// Run the CLI
$cli = new LazyMeCLI();
$cli->run($argv);
?> 

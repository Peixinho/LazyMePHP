class LazyMeCLI {
    private array $commands = [
        'serve'            => 'Start the PHP development server',
        'build'            => 'Run the build tools for forms and APIs',
        'batman'           => 'Start the Batman dashboard server',
        'auth:hash'        => 'Hash a plain-text password for storage',
        'migrate'          => 'Run all pending migrations',
        'migrate:rollback' => 'Roll back the last migration batch  [--step=N]',
        'migrate:reset'    => 'Roll back every migration',
        'migrate:fresh'    => 'Drop all tables and re-run every migration',
        'migrate:status'   => 'Show which migrations have run',
        'make:migration'   => 'Scaffold a new migration file  [name]',
        'make:api'         => 'GraphQL API is auto-generated — shows how to customise field exposure',
        'make:view'        => 'Generic Blade views are built-in — shows how to override per-table',
        'make:controller'  => 'CrudController handles all tables — shows how to subclass',
        'make:route'       => 'AutoRouter registers routes at runtime — shows how it works',
        'make:all'         => 'Shows guidance for views, controller, routes, and API for a table',
        'schema:cache'     => 'Cache DB schema to files (avoids per-request introspection)',
        'schema:clear'     => 'Remove cached schema files',
        'db:seed'          => 'Run database seeders  [--class=Name]',
        'make:seeder'      => 'Scaffold a new seeder file  [name]',
        'make:factory'     => 'Scaffold a new model factory  [name]',
        'make:observer'    => 'Scaffold a new model observer  [name]',
        'make:resource'    => 'Scaffold a new API resource  [name]',
        'make:model'       => 'Scaffold a new Model subclass  [name] [--table=TableName]',
        'make:job'         => 'Scaffold a new queue job  [name]',
        'make:request'     => 'Scaffold a new FormRequest  [name]',
        'make:mail'        => 'Scaffold a new Mailable class  [name]',
        'queue:work'       => 'Start the queue worker  [--queue=default --sleep=3 --tries=3 --stop-when-empty]',
        'queue:size'       => 'Show number of pending jobs  [--queue=default]',
    ];

    public function run(array $argv): void {
        if (!isset($argv[1])) {
            $this->showHelp();
            exit(0);
        }

        $command = $argv[1];
        $tableName = $argv[2] ?? null;

        // Parse --step=N, --class=Name, --queue=X, --sleep=N, --tries=N, --stop-when-empty, --table=Name
        $step          = 1;
        $classArg      = null;
        $queueArg      = 'default';
        $sleepArg      = 3;
        $triesArg      = 3;
        $stopWhenEmpty = false;
        $tableArg      = null;
        foreach ($argv as $arg) {
            if (preg_match('/^--step=(\d+)$/',  $arg, $m)) { $step      = (int)$m[1]; }
            if (preg_match('/^--class=(.+)$/',   $arg, $m)) { $classArg  = $m[1]; }
            if (preg_match('/^--queue=(.+)$/',   $arg, $m)) { $queueArg  = $m[1]; }
            if (preg_match('/^--sleep=(\d+)$/',  $arg, $m)) { $sleepArg  = (int)$m[1]; }
            if (preg_match('/^--tries=(\d+)$/',  $arg, $m)) { $triesArg  = (int)$m[1]; }
            if (preg_match('/^--table=(.+)$/',   $arg, $m)) { $tableArg  = $m[1]; }
            if ($arg === '--stop-when-empty') { $stopWhenEmpty = true; }
        }

        switch($command) {
            case 'serve':
                $this->serve();
                break;
            case 'build':
                $this->build();
                break;
            case 'batman':
                $this->batman();
                break;
            case 'auth:hash':
                if (!$tableName) {
                    echo "Usage: php LazyMePHP auth:hash <password>\n";
                    exit(1);
                }
                echo \Core\Auth\Auth::hashPassword($tableName) . "\n";
                break;
            case 'migrate':
                \Core\Migration\Runner::run();
                break;
            case 'migrate:rollback':
                \Core\Migration\Runner::rollback($step);
                break;
            case 'migrate:reset':
                \Core\Migration\Runner::reset();
                break;
            case 'migrate:fresh':
                \Core\Migration\Runner::fresh();
                break;
            case 'migrate:status':
                \Core\Migration\Runner::status();
                break;
            case 'make:migration':
                if (!$tableName) {
                    echo "Usage: php LazyMePHP make:migration <name>\n";
                    exit(1);
                }
                $path = \Core\Migration\Runner::scaffold($tableName);
                echo "Created: $path\n";
                break;
            case 'make:view':
                $this->makeView($tableName);
                break;
            case 'make:controller':
                $this->makeController($tableName);
                break;
            case 'make:route':
                $this->makeRoute($tableName);
                break;
            case 'make:all':
                $this->makeAll($tableName);
                break;
            case 'make:api':
                $this->makeApi($tableName);
                break;
            case 'schema:cache':
                $this->schemaCache($tableName);
                break;
            case 'schema:clear':
                $this->schemaClear($tableName);
                break;
            case 'db:seed':
                (new \Core\Seeder\Runner())->run($classArg);
                break;
            case 'make:seeder':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:seeder <Name>\n";
                    exit(1);
                }
                $this->makeSeeder($tableName);
                break;
            case 'make:factory':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:factory <Name>\n";
                    exit(1);
                }
                $this->makeFactory($tableName);
                break;
            case 'make:observer':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:observer <Name>\n";
                    exit(1);
                }
                $this->makeObserver($tableName);
                break;
            case 'make:resource':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:resource <Name>\n";
                    exit(1);
                }
                $this->makeResource($tableName);
                break;
            case 'make:model':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:model <Name> [--table=TableName]\n";
                    exit(1);
                }
                $this->makeModel($tableName, $tableArg);
                break;
            case 'make:job':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:job <Name>\n";
                    exit(1);
                }
                $this->makeJob($tableName);
                break;
            case 'make:request':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:request <Name>\n";
                    exit(1);
                }
                $this->makeRequest($tableName);
                break;
            case 'make:mail':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:mail <Name>\n";
                    exit(1);
                }
                $this->makeMail($tableName);
                break;
            case 'queue:work':
                (new \Core\Queue\Worker())->run($queueArg, $sleepArg, $triesArg, $stopWhenEmpty);
                break;
            case 'queue:size':
                echo "Pending jobs on '{$queueArg}': " . \Core\Queue\Queue::size($queueArg) . "\n";
                break;
            default:
                echo "Unknown command: $command\n";
                $this->showHelp();
                exit(1);
        }
    }

    private function showHelp(): void {
        echo "LazyMePHP CLI Tool\n";
        echo "Usage: php LazyMePHP [command] [table_name]\n\n";
        echo "Available commands:\n";
        foreach ($this->commands as $command => $description) {
            echo "  " . str_pad($command, 15) . " $description\n";
        }
    }

    private function serve(): void {
        require_once __DIR__ . '/App/Tools/ServerOutput';
        $port = $this->getPort(8080);
        ServerOutput::printBanner('Web', '1.0.0');
        $host = 'localhost';
        $docRoot = __DIR__ . '/public';
        ServerOutput::printServerInfo($host, $port, $docRoot);
        echo "Starting development server on port $port...\n";
        echo "Server will be available at: http://localhost:$port\n";
        echo "Press Ctrl+C to stop the server.\n";
        @exec("php -S 0.0.0.0:$port -t ./public App/Tools/Webserver");
    }

    private function build(): void {
        echo "Running build tools...\n";
        if (file_exists(__DIR__.'/App/Tools/build')) {
            require_once __DIR__.'/App/Tools/build';
        } else {
            echo "Build script (App/Tools/build) not found.\n";
            exit(1);
        }
    }

    private function batman(): void {
        require_once __DIR__ . '/App/Tools/ServerOutput';
        $port = $this->getPort(8081);
        ServerOutput::printBanner('Batman', '1.0.0');
        $host = 'localhost';
        ServerOutput::printBatmanInfo($host, $port);
        echo "Starting Batman dashboard server...\n";
        echo "Batman dashboard will be available at: http://localhost:$port\n";
        echo "Press Ctrl+C to stop the server.\n";
        @exec("php -S 0.0.0.0:$port -t ./batman App/Tools/BatmanServer");

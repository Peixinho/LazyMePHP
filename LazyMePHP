    private function makeAll(?string $tableName): void {
        $this->makeView($tableName);
        $this->makeController($tableName);
        $this->makeRoute($tableName);
        $this->makeApi($tableName);
    }

    private function makeApi(?string $tableName): void {
        echo "\n\u{1F4A1} The API is now a GraphQL endpoint at POST /graphql — no code generation needed.\n";
        echo "   Core\\GraphQL\\SchemaBuilder builds the schema from all tables at runtime.\n";
        if ($tableName) {
            echo "   To restrict fields for '$tableName', override exposedFields() in App/Controllers/{$tableName}.php:\n\n";
            echo "     protected function exposedFields(): array {\n";

    public function run(array $argv): void {
        if (!isset($argv[1])) {
            $this->showHelp();
            exit(0);
        }

        $command = $argv[1];
        $tableName = $argv[2] ?? null;

        // Parse --step=N, --class=Name, --queue=X, --sleep=N, --tries=N, --stop-when-empty, --table=Name
        $step          = 1;
        $classArg      = null;
        $queueArg      = 'default';
        $sleepArg      = 3;
        $triesArg      = 3;
        $stopWhenEmpty = false;
        $tableArg      = null;
        foreach ($argv as $arg) {
            if (preg_match('/^--step=(\d+)$/',  $arg, $m)) { $step      = (int)$m[1]; }
            if (preg_match('/^--class=(.+)$/',   $arg, $m)) { $classArg  = $m[1]; }
            if (preg_match('/^--queue=(.+)$/',   $arg, $m)) { $queueArg  = $m[1]; }
            if (preg_match('/^--sleep=(\d+)$/',  $arg, $m)) { $sleepArg  = (int)$m[1]; }
            if (preg_match('/^--tries=(\d+)$/',  $arg, $m)) { $triesArg  = (int)$m[1]; }
            if (preg_match('/^--table=(.+)$/',   $arg, $m)) { $tableArg  = $m[1]; }
            if ($arg === '--stop-when-empty') { $stopWhenEmpty = true; }
        }

        switch($command) {
            case 'serve':
                $this->serve();
                break;
            case 'build':
                $this->requireDatabase('build');
                $this->build();
                break;
            case 'batman':
                $this->batman();
                break;
            case 'auth:hash':
                if (!$tableName) {
                    echo "Usage: php LazyMePHP auth:hash <password>\n";
                    exit(1);
                }
                echo \Core\Auth\Auth::hashPassword($tableName) . "\n";
                break;
            case 'migrate':
                $this->requireDatabase('migrate');
                \Core\Migration\Runner::run();
                break;
            case 'migrate:rollback':
                $this->requireDatabase('migrate:rollback');
                \Core\Migration\Runner::rollback($step);
                break;
            case 'migrate:reset':
                $this->requireDatabase('migrate:reset');
                \Core\Migration\Runner::reset();
                break;
            case 'migrate:fresh':
                $this->requireDatabase('migrate:fresh');
                \Core\Migration\Runner::fresh();
                break;
            case 'migrate:status':
                $this->requireDatabase('migrate:status');
                \Core\Migration\Runner::status();
                break;
            case 'make:migration':
                if (!$tableName) {
                    echo "Usage: php LazyMePHP make:migration <name>\n";
                    exit(1);
                }
                $path = \Core\Migration\Runner::scaffold($tableName);
                echo "Created: $path\n";
                break;
            case 'make:view':
                $this->makeView($tableName);
                break;
            case 'make:controller':
                $this->makeController($tableName);
                break;
            case 'make:route':
                $this->makeRoute($tableName);
                break;
            case 'make:all':
                $this->makeAll($tableName);
                break;
            case 'make:api':
                $this->makeApi($tableName);
                break;
            case 'schema:cache':
                $this->schemaCache($tableName);
                break;
            case 'schema:clear':
                $this->schemaClear($tableName);
                break;
            case 'db:seed':
                (new \Core\Seeder\Runner())->run($classArg);
                break;
            case 'make:seeder':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:seeder <Name>\n";
                    exit(1);
                }
                $this->makeSeeder($tableName);
                break;
            case 'make:factory':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:factory <Name>\n";
                    exit(1);
                }
                $this->makeFactory($tableName);
                break;
            case 'make:observer':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:observer <Name>\n";
                    exit(1);
                }
                $this->makeObserver($tableName);
                break;
            case 'make:resource':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:resource <Name>\n";
                    exit(1);
                }
                $this->makeResource($tableName);
                break;
            case 'make:model':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:model <Name> [--table=TableName]\n";
                    exit(1);
                }
                $this->makeModel($tableName, $tableArg);
                break;
            case 'make:job':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:job <Name>\n";
                    exit(1);
                }
                $this->makeJob($tableName);
                break;
            case 'make:request':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:request <Name>\n";
                    exit(1);
                }
                $this->makeRequest($tableName);
                break;
            case 'make:mail':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:mail <Name>\n";
                    exit(1);
                }
                $this->makeMail($tableName);
                break;
            case 'make:test':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:test <Name>\n";
                    exit(1);
                }
                $this->makeTest($tableName);
                break;
            case 'make:command':
                if (!$tableName) {
                    echo "Usage: php lazymephp make:command <Name>\n";
                    exit(1);
                }
                $this->makeCommand($tableName);
                break;
            case 'queue:work':
                (new \Core\Queue\Worker())->run($queueArg, $sleepArg, $triesArg, $stopWhenEmpty);
                break;
            case 'queue:size':
                echo "Pending jobs on '{$queueArg}': " . \Core\Queue\Queue::size($queueArg) . "\n";
                break;
            case 'queue:failed':
                $this->queueFailed($queueArg);
                break;
            case 'queue:retry':
                if ($tableName === null) { echo "Usage: php LazyMePHP queue:retry <id>\n"; exit(1); }
                \Core\Queue\Queue::retry($tableName);
                echo "Job {$tableName} re-queued.\n";
                break;
            case 'queue:flush':
                \Core\Queue\Queue::flush($queueArg);
                echo "Flushed failed jobs on '{$queueArg}'.\n";
                break;
            case 'route:list':
                $this->routeList();
                break;
            case 'optimize':
                $this->optimize();
                break;
            case 'schedule:run':
                $this->scheduleRun();
                break;
            default:
                // Check user-defined commands in App/Console/Commands/
                if ($this->runUserCommand($command, array_slice($argv, 2))) {
                    break;
                }
                echo "Unknown command: $command\n";
                $this->showHelp();
                exit(1);
        }
    }

    private function scheduleRun(): void {
        $kernelFile = __DIR__ . '/App/Console/Kernel.php';
        if (!file_exists($kernelFile)) {
            echo "No App/Console/Kernel.php found. Nothing to run.\n";
            return;
        }
        require_once $kernelFile;
        $kernel   = new \App\Console\Kernel();
        $schedule = new \Core\Console\Schedule();
        $kernel->schedule($schedule);
        $now  = new \DateTimeImmutable();
        $ran  = 0;
        foreach ($schedule->tasks() as $task) {
            if (!$task->isDue($now)) continue;
            $desc = $task->getDescription() ?: $task->getCronExpression();
            echo "Running: {$desc}\n";
            try {
                $task->run();
                $ran++;
            } catch (\Throwable $e) {
                echo "  ERROR: {$e->getMessage()}\n";
            }
        }
        echo $ran > 0 ? "{$ran} task(s) ran.\n" : "No tasks due.\n";
    }

    private function runUserCommand(string $name, array $args): bool {
        $dir = __DIR__ . '/App/Console/Commands';
        if (!is_dir($dir)) return false;
        foreach (glob($dir . '/*.php') ?: [] as $file) {
            require_once $file;
        }
        foreach (get_declared_classes() as $class) {
            if (!is_subclass_of($class, \Core\Console\Command::class)) continue;
            $cmd = new $class();
            if ($cmd->getName() !== $name) continue;
            $cmd->setArgs($args);
            $cmd->handle();
            return true;
        }
        return false;
    }


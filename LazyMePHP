        if (!is_dir($dir)) mkdir($dir, 0755, true);

        $class = $this->studly($tableName);
        $file  = "$dir/{$class}.php";
        if (file_exists($file)) {
            echo "Controller already exists: $file\n";
            exit(1);
        }

        $hidden = $hiddenFlag;
        if (!$hiddenFlag && $this->isInteractive()) {
            $hidden = $this->promptYesNo("Hide '{$tableName}' from auto-routing and the GraphQL schema?");

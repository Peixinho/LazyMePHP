# Database — choose one driver and fill in the relevant fields
DB_TYPE=mysql
DB_HOST=localhost
DB_NAME=mydatabase
DB_USER=root
DB_PASSWORD=
DB_FILE_PATH=

# Application
APP_NAME=LazyMePHP
APP_TITLE="LazyMePHP Application"
APP_VERSION=1.0
APP_DESCRIPTION="A LazyMePHP application."
APP_TIMEZONE=UTC
APP_NRESULTS=100
APP_EMAIL_SUPPORT=support@example.com

# Environment — set to "development" to enable GraphQL introspection and the debug toolbar
APP_ENV=production
APP_DEBUG_MODE=false

# Encryption key — generate a strong random key before deploying:
#   php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
APP_ENCRYPTION=REPLACE_WITH_A_STRONG_RANDOM_KEY

# CORS — set to the exact origin you want to allow for cross-origin API requests.
# Leave empty to block all cross-origin requests (safe default).
APP_CORS_ORIGIN=

# Authentication (JWT) — uncomment and set to enable POST /auth/login, /auth/logout, GET /auth/me
# Protect routes by adding ->addMiddleware(\Core\Auth\JwtMiddleware::class)
# AUTH_TABLE=users
# AUTH_USERNAME_COLUMN=email
# AUTH_PASSWORD_COLUMN=password
# AUTH_TOKEN_TTL=3600
# AUTH_REFRESH_TTL=2592000

# Password reset — run `php LazyMePHP migrate` to create __AUTH_PASSWORD_RESETS
# AUTH_PASSWORD_RESET_TTL=3600

# Email verification — run `php LazyMePHP migrate` to create __AUTH_EMAIL_VERIFICATIONS
# AUTH_EMAIL_VERIFY_TTL=86400
# AUTH_EMAIL_VERIFIED_COLUMN=email_verified_at

# Cache driver — array (in-process, default) | apcu | redis
# CACHE_DRIVER=array
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Queue driver — sync (inline, default) | database | redis
# Run the worker with: php LazyMePHP queue:work
# QUEUE_DRIVER=sync

# File storage
# STORAGE_DRIVER=local
# STORAGE_PATH=storage/app
# STORAGE_URL=/storage

# Multi-tenancy — set TENANT_TABLE to the tenants table to enable
# TENANT_TABLE=tenants
# TENANT_COLUMN=slug
# TENANT_RESOLVE=subdomain    # subdomain | header | path | jwt
# TENANT_REQUIRE=true

# OpenAPI — set to false to disable GET /openapi.json
OPENAPI_ENABLED=true

# Activity logging — records inserts/updates/deletes in __LOG_ACTIVITY
APP_ACTIVITY_LOG=false
APP_ACTIVITY_AUTH=

# Batman dashboard credentials — generate the secret hash with:
#   php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT), PHP_EOL;"
# BATMAN_USERNAME=admin
# BATMAN_SECRET=
